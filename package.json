{
  "name": "heirloom",
  "version": "0.1.0",
  "description": "CLI tool that digitizes handwritten and printed family recipes from photographs into structured, searchable data",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --max-old-space-size=4096 node_modules/jest/bin/jest.js --maxWorkers=2",
    "clean": "rm -rf dist",
    "init": "npx tsx bin/heirloom.ts init",
    "ingest": "npx tsx bin/heirloom.ts ingest",
    "transcribe": "npx tsx bin/heirloom.ts transcribe",
    "export": "npx tsx bin/heirloom.ts export",
    "jobs": "npx tsx bin/heirloom.ts jobs",
    "use": "npx tsx bin/heirloom.ts use"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1038.0",
    "@aws-sdk/client-dynamodb": "^3.1038.0",
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/client-textract": "^3.1038.0",
    "@aws-sdk/lib-dynamodb": "^3.1038.0",
    "aws-cdk-lib": "^2.200.0",
    "constructs": "^10.4.2",
    "convict": "^6.2.4",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "sharp": "^0.35.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/convict": "^6.1.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "@types/pdfkit": "^0.17.6",
    "@types/sharp": "^0.31.1",
    "fast-check": "^4.1.1",
    "jest": "^30.0.4",
    "ts-jest": "^29.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "yaml": "^2.8.3"
  }
}
