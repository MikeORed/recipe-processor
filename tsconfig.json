{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "bin/**/*.ts",
    "src/**/*.ts",
    "infra/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.unit.ts",
    "**/*.pbt.ts",
    "**/*.test.ts",
    "jest.config.ts"
  ]
}
